<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<title>未来選択ストーリーゲーム</title>
<style>
body {
  margin: 0;
  font-family: sans-serif;
  background: linear-gradient(120deg, #f6d365, #fda085);
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
}
.card {
  background: white;
  padding: 25px;
  border-radius: 20px;
  width: 450px;
  box-shadow: 0 10px 25px rgba(0,0,0,0.2);
}
.story {
  font-size: 16px;
  margin-bottom: 15px;
}
.question {
  font-size: 18px;
  margin: 15px 0;
}
button {
  width: 100%;
  padding: 12px;
  margin: 6px 0;
  border: none;
  border-radius: 10px;
  cursor: pointer;
  background: #ff7e5f;
  color: white;
  transition: 0.2s;
}
button:hover { transform: scale(1.03); }
.result { text-align: center; }
.type { font-size: 22px; font-weight: bold; margin: 10px 0; }
.job { font-size: 14px; color: #555; }
</style>
</head>
<body>
<div class="card">
  <div id="game"></div>
</div>

<script>
const steps = [
  {
    story: "あなたは進路に迷っている高校生。文化祭の準備が始まった。",
    question: "どんな役割を選ぶ？",
    options: [
      { text: "全体をまとめる", type: "business" },
      { text: "ポスターや装飾を作る", type: "art" },
      { text: "仕組みや装置を作る", type: "engineering" },
      { text: "みんなを支える", type: "education" }
    ]
  },
  {
    story: "友達と将来の話になった。",
    question: "どんな話題に興味がある？",
    options: [
      { text: "会社やお金の仕組み", type: "business" },
      { text: "映画やデザイン", type: "art" },
      { text: "AIやテクノロジー", type: "engineering" },
      { text: "教育や人の成長", type: "education" }
    ]
  },
  {
    story: "放課後、自由時間。",
    question: "何をして過ごす？",
    options: [
      { text: "計画や戦略を考える", type: "business" },
      { text: "絵や作品を作る", type: "art" },
      { text: "プログラミングや実験", type: "engineering" },
      { text: "誰かの相談に乗る", type: "education" }
    ]
  },
  {
    story: "進路相談の時間。",
    question: "先生に何を相談する？",
    options: [
      { text: "将来の仕事や起業", type: "business" },
      { text: "クリエイティブな道", type: "art" },
      { text: "技術職や研究", type: "engineering" },
      { text: "人を支える仕事", type: "education" }
    ]
  }
];

const results = {
  business: {
    name: "経済・経営学部",
    desc: "社会やビジネスの仕組みを学ぶ分野",
    jobs: "例：起業家、マーケター、銀行員"
  },
  art: {
    name: "芸術・デザイン学部",
    desc: "表現や創造を追求する分野",
    jobs: "例：デザイナー、イラストレーター、映像クリエイター"
  },
  engineering: {
    name: "工学・情報学部",
    desc: "技術で社会を支える分野",
    jobs: "例：エンジニア、プログラマー、研究者"
  },
  education: {
    name: "教育・福祉学部",
    desc: "人を育て、支える分野",
    jobs: "例：教師、カウンセラー、福祉職"
  }
};

let index = 0;
let score = { business:0, art:0, engineering:0, education:0 };

const game = document.getElementById("game");

function showStep() {
  if (index >= steps.length) {
    showResult();
    return;
  }

  const s = steps[index];

  let html = `<div class="story">${s.story}</div>`;
  html += `<div class="question">${s.question}</div>`;

  s.options.forEach(opt => {
    html += `<button onclick="answer('${opt.type}')">${opt.text}</button>`;
  });

  game.innerHTML = html;
}

function answer(type) {
  score[type]++;
  index++;
  showStep();
}

function showResult() {
  let maxType = Object.keys(score).reduce((a,b)=> score[a]>score[b]?a:b);

  game.innerHTML = `
    <div class="result">
      <div>あなたに向いているのは</div>
      <div class="type">${results[maxType].name}</div>
      <div>${results[maxType].desc}</div>
      <div class="job">${results[maxType].jobs}</div>
    </div>
  `;
}

showStep();
</script>
</body>
</html>
